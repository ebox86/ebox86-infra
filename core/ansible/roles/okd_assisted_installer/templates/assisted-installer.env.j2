# Environment variables for OKD Assisted Installer
# Used by docker-compose.yml when deploying the container stack

# PostgreSQL database credentials
POSTGRES_PASSWORD={{ lookup('password', 'passwords/assisted_installer_db_password chars=ascii_letters,digits length=32') }}

# MinIO object storage credentials (used by assisted-service to store ignition configs)
MINIO_PASSWORD={{ lookup('password', 'passwords/assisted_installer_minio_password chars=ascii_letters,digits length=32') }}

# Assisted Service API configuration
ASSISTED_SERVICE_HOST=0.0.0.0
ASSISTED_SERVICE_PORT=8090

# Cluster configuration defaults (can be overridden in UI)
CLUSTER_NAME={{ okd_cluster.name }}
CLUSTER_DOMAIN={{ okd_cluster.domain }}
OPENSHIFT_VERSION=4.22

# Network configuration
CLUSTER_NETWORK_CIDR={{ okd_cluster.cluster_network_cidr }}
SERVICE_NETWORK_CIDR={{ okd_cluster.service_network_cidr }}

# VIP configuration (used during cluster bootstrap)
API_VIP={{ okd_api_vip }}
INGRESS_VIP={{ okd_ingress_vip }}

# Storage and cache directories
ISO_CACHE_DIR=/tmp/iso-cache
ASSISTED_SERVICE_DATA_DIR=/var/lib/assisted

# Logging
LOG_LEVEL=info
PROFILING_MODE=false
