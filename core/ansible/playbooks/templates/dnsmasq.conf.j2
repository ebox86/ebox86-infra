# /etc/dnsmasq.conf — generated by Ansible (playbook 64_deploy_dhcp_lxc.yml)
# DO NOT EDIT MANUALLY — changes will be overwritten on next playbook run.
#
# dnsmasq on dhcp-01 serves DHCP for all LAN VLANs (10-70).
# DNS is disabled (port=0) — this is a DHCP-only server.
# The 9004 (10.x.0.1) is the L3 default gateway for every VLAN.
#
# Uses listen-address + subnet-tagged dhcp-range instead of interface= so
# that interface names (ens18, ens19, …) don't need to be hardcoded.

# Disable DNS
port=0

# Bind only to the addresses listed in listen-address directives.
# Required for multi-interface DHCP — prevents dnsmasq from answering
# on interfaces that aren't explicitly listed.
bind-interfaces

# Log DHCP activity (journalctl -u dnsmasq)
log-dhcp

# Upstream DNS servers pushed to clients via DHCP option 6
# dns-01 (10.20.0.20) is primary; 1.1.1.1 is fallback
dhcp-option=option:dns-server,10.20.0.20,1.1.1.1

# =========================================================================
# Static DHCP reservations — devices that must always get the same IP
# =========================================================================

{% for host in dhcp_static_hosts | default([]) %}
dhcp-host={{ host.mac }},{{ host.ip }}{% if host.name is defined %},{{ host.name }}{% endif %}

{% endfor %}

# =========================================================================
# Per-VLAN listen addresses
# dnsmasq matches each dhcp-range to the interface whose IP is in that
# subnet — no need to reference interface names directly.
# =========================================================================

{% for vlan in vlans %}
listen-address={{ vlan.gateway | regex_replace('\.1$', '.5') }}
{% endfor %}

# =========================================================================
# Per-VLAN DHCP pools
#
# Pattern per VLAN:
#   dhcp-range=set:<tag>, <start>, <end>, <mask>, <lease>
#   dhcp-option=tag:<tag>, option:router, <gateway>
#
# IP layout:
#   10.x.0.1   — 9004 VLAN SVI (default gateway)
#   10.x.0.5   — this server (dhcp-01)
#   10.x.0.10-49 — reserved for static assignments
#   10.x.0.50-250 — DHCP pool
# =========================================================================

{% for vlan in vlans %}
# VLAN {{ vlan.id }} — {{ vlan.name }} ({{ vlan.description }})
dhcp-range=set:vlan{{ vlan.id }},{{ vlan.gateway | regex_replace('\.1$', '.50') }},{{ vlan.gateway | regex_replace('\.1$', '.250') }},255.255.255.0,24h
dhcp-option=tag:vlan{{ vlan.id }},option:router,{{ vlan.gateway }}
dhcp-option=tag:vlan{{ vlan.id }},option:netmask,255.255.255.0

{% endfor %}
